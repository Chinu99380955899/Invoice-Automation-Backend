# =====================================================
# Invoice Automation Backend - Environment Configuration
# =====================================================

# --- Application ---
APP_NAME=InvoiceAutomation
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Security ---
SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database (PostgreSQL) ---
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=invoice_pass
POSTGRES_DB=invoice_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://invoice_user:invoice_pass@localhost:5432/invoice_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_DEFAULT_QUEUE=invoices

# --- Storage ---
# Options: local | azure
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=invoices
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,tiff,tif

# --- Azure Document Intelligence (Champ OCR) ---
AZURE_DI_ENDPOINT=
AZURE_DI_KEY=
AZURE_DI_MODEL=prebuilt-invoice
# Use mock if credentials are not configured
USE_MOCK_AZURE_OCR=true

# --- PaddleOCR (Challenger) ---
PADDLE_OCR_LANG=en
PADDLE_OCR_USE_GPU=false
USE_MOCK_PADDLE_OCR=true

# --- Validation thresholds ---
CONFIDENCE_THRESHOLD=0.85
AMOUNT_TOLERANCE=0.01
FIELD_MATCH_THRESHOLD=0.90

# --- External integrations ---
SAP_API_URL=http://mock-sap.internal/api
SAP_API_KEY=mock-sap-key
SALESFORCE_API_URL=http://mock-salesforce.internal/api
SALESFORCE_API_KEY=mock-sf-key
USE_MOCK_INTEGRATIONS=true

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
